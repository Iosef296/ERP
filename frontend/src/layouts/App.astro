---
const { title = 'Ruashka ERP' } = Astro.props
---
<!DOCTYPE html>
<html lang="es">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <title>{title} | Ruashka ERP</title>
  <style>
    * { margin: 0; padding: 0; box-sizing: border-box; }
    body { font-family: system-ui, sans-serif; display: flex; min-height: 100vh; background: #f4f6f9; }
    main { flex: 1; padding: 2rem; overflow-y: auto; }
  </style>
</head>
<body>
  <aside id="sidebar">
    <slot name="sidebar" />
  </aside>
  <main>
    <slot />
  </main>
</body>
</html>
